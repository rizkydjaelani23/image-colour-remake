<div
  class="pcg-root"
  data-product-id="{{ product.id }}"
  data-shop="{{ shop.permanent_domain }}"
  data-heading="{{ block.settings.heading | escape }}"
  data-subtext="{{ block.settings.subtext | escape }}"
  data-collapsed-label="{{ block.settings.collapsed_label | escape }}"
  data-disclaimer="{{ block.settings.disclaimer_text | escape }}"
  data-show-disclaimer="{{ block.settings.show_disclaimer }}"
  data-open-by-default="{{ block.settings.open_by_default }}"
  data-show-colour-preview="{{ block.settings.show_colour_preview }}"
  data-show-colour-preview-mobile="{{ block.settings.show_colour_preview_mobile }}"
  style="
    --pcg-box-bg: {{ block.settings.box_bg }};
    --pcg-box-border: {{ block.settings.box_border }};
    --pcg-box-radius: {{ block.settings.box_radius }}px;
    --pcg-accent: {{ block.settings.accent_color }};
    --pcg-card-bg: {{ block.settings.card_bg }};
    --pcg-card-active-bg: {{ block.settings.card_active_bg }};
    --pcg-text: {{ block.settings.text_color }};
    --pcg-subtext: {{ block.settings.subtitle_color }};
  "
  {{ block.shopify_attributes }}
></div>

{% schema %}
{
  "name": "Product colour gallery",
  "target": "section",
  "stylesheet": "gallery.css",
  "javascript": "gallery.js",
  "settings": [
    {
      "type": "text",
      "id": "collapsed_label",
      "label": "Collapsed title",
      "default": "See more colours"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Expanded heading",
      "default": "See this bed in other colours"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtitle text",
      "default": "Browse approved colour options for this product."
    },
    {
      "type": "checkbox",
      "id": "show_disclaimer",
      "label": "Show disclaimer text",
      "default": true
    },
    {
      "type": "text",
      "id": "disclaimer_text",
      "label": "Disclaimer text",
      "default": "Image designs are approximately 80% accurate."
    },
    {
      "type": "checkbox",
      "id": "open_by_default",
      "label": "Open by default",
      "default": false
    },
    {
      "type": "header",
      "content": "Colour preview"
    },
    {
      "type": "checkbox",
      "id": "show_colour_preview",
      "label": "Show preview image on desktop",
      "info": "When enabled, clicking a colour swatch shows a larger preview image inside the gallery on desktop. Turn off if your theme already displays the image beside the main product photo.",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_colour_preview_mobile",
      "label": "Show preview image on mobile",
      "info": "Controls the inline preview image separately for mobile devices. Turn off to swap the main product image instead.",
      "default": true
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "box_bg",
      "label": "Box background colour",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "box_border",
      "label": "Box border colour",
      "default": "#e5e7eb"
    },
    {
      "type": "range",
      "id": "box_radius",
      "label": "Corner roundness",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour",
      "info": "Used for active colour card borders, selected fabric buttons, and the preview label bar.",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Colour card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "card_active_bg",
      "label": "Selected card background colour",
      "info": "The background colour a colour card turns when clicked/selected.",
      "default": "#f0f4ff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text colour",
      "info": "Applies to headings, card titles, and the toggle label.",
      "default": "#111827"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Subtitle text colour",
      "info": "Applies to the smaller description text beneath the toggle label.",
      "default": "#6b7280"
    }
  ]
}
{% endschema %}
