generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum PreviewStatus {
  DRAFT
  APPROVED
  HIDDEN
  FEATURED
}

model Shop {
  id          String   @id @default(cuid())
  shopDomain  String   @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Fabric SEO Engine add-on
  // seoAddonActive is flipped true by the billing webhook when a merchant pays.
  // During development, the isSeoAddonActive() utility bypasses this flag via env var.
  seoAddonActive         Boolean   @default(false)
  seoAddonSubscriptionId String?   // Shopify subscription GID stored on activation
  seoAddonActivatedAt    DateTime? // When they first subscribed

  usage ShopUsage?

  products      Product[]
  zones         Zone[]
  swatches      Swatch[]
  previews      Preview[]
  conversations SupportConversation[]
  gscConnection GscConnection?
}

model Product {
  id               String   @id @default(cuid())
  shopId           String
  shopifyProductId String
  title            String?
  handle           String?
  imageUrl         String?
  showOnStorefront Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  zones    Zone[]
  previews Preview[]

  @@unique([shopId, shopifyProductId])
  @@index([shopId])
}

model Zone {
  id           String   @id @default(cuid())
  shopId       String
  productId    String
  name         String
  key          String
  maskPath     String?
  outlinePath  String?
  geometryJson Json?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  previews Preview[]

  @@unique([productId, key])
  @@index([shopId, productId])
}

model Swatch {
  id           String   @id @default(cuid())
  shopId       String
  fabricFamily String
  colourName   String
  imagePath    String
  imageUrl     String?
  hex          String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop     Shop      @relation(fields: [shopId], references: [id], onDelete: Cascade)
  previews Preview[]

  @@unique([shopId, fabricFamily, colourName])
  @@index([shopId, fabricFamily])
}

model Preview {
  id                    String        @id @default(cuid())
  shopId                String
  productId             String
  zoneId                String
  swatchId              String?
  shopifyProductId      String
  fabricFamily          String
  colourName            String
  imagePath             String
  imageUrl              String
  thumbUrl              String?
  width                 Int?
  height                Int?
  customerDisplayName   String?
  status                PreviewStatus @default(DRAFT)
  approvedForStorefront Boolean       @default(false)
  featured              Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  shop    Shop    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  zone    Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  swatch  Swatch? @relation(fields: [swatchId], references: [id], onDelete: SetNull)

  @@unique([productId, zoneId, fabricFamily, colourName])
  @@index([shopId, productId])
  @@index([shopId, fabricFamily])
  @@index([zoneId])
  @@index([approvedForStorefront, featured])
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)

  refreshToken        String?
  refreshTokenExpires DateTime?
}

model SupportConversation {
  id         String   @id @default(cuid())
  shopId     String
  shopDomain String
  status     String   @default("open") // open | closed
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  shop     Shop             @relation(fields: [shopId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([shopId])
  @@index([status])
}

model SupportMessage {
  id             String   @id @default(cuid())
  conversationId String
  body           String
  sender         String   // "merchant" | "support" | "system"
  createdAt      DateTime @default(now())

  conversation SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model GscConnection {
  id             String    @id @default(cuid())
  shopId         String    @unique
  siteUrl        String                        // GSC property URL (e.g. "https://store.com/" or "sc-domain:store.com")
  accessToken    String    @db.Text
  refreshToken   String    @db.Text
  expiresAt      DateTime
  cachedData     String?   @db.Text            // JSON: Record<collectionHandle, { clicks, impressions, position }>
  cacheUpdatedAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}

model ShopUsage {
  id           String   @id @default(cuid())
  shopId       String   @unique
  previewCount Int      @default(0)
  previewLimit Int      @default(50)
  periodStart  DateTime @default(now())
  periodEnd    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  shop Shop @relation(fields: [shopId], references: [id], onDelete: Cascade)
}
